@model BookLibrary.ViewModels.Books.BookDeleteViewModel

@{
    ViewData["Title"] = "Delete Book";
}

<div>
    <h2 class="text-center text-danger">@ViewData["Title"]</h2>
    <strong>Are you sure you want to delete this book?</strong>
</div>

<form asp-controller="Books" asp-action="DeleteConfirmed" method="post">
    <input type="hidden" name="id" value="@Model.Id" />

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index" class="btn btn-secondary ms-2">
        Cancel
    </a>
</form>