@model IEnumerable<BookLibrary.ViewModels.Countries.CountryIndexViewModel>

@{
    ViewData["Title"] = "Countries";
}

<div class="glass-card p-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="mb-0 fw-bold text-dark">
            🌍 Countries
        </h2>

        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-success px-3">
                <i class="bi bi-plus-circle"></i> Add Country
            </a>
        }

    </div>

    <div class="table-responsive">

        <table class="table align-middle table-hover">

            <thead class="table-light">
                <tr>
                    <th>Country</th>

                    @if (User.IsInRole("Admin"))
                    {
                        <th class="text-center">Actions</th>
                    }
                </tr>
            </thead>

            <tbody>

                @foreach (var country in Model)
                {
                    <tr>

                        <td class="fw-semibold">
                            <i class="bi bi-globe2 text-secondary me-2"></i>
                            @country.Name
                        </td>

                        @if (User.IsInRole("Admin"))
                        {
                            <td class="text-center">

                                <a asp-action="Edit"
                                       asp-route-id="@country.Id"
                                       class="btn btn-warning btn-sm me-2">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <a asp-action="Delete"
                                       asp-route-id="@country.Id"
                                       class="btn btn-danger btn-sm">
                                    <i class="bi bi-trash"></i>
                                </a>

                            </td>
                        }

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>