@{
    ViewData["Title"] = "Admin Panel";
}

<h2 class="text-center mb-4">Admin Panel</h2>
<hr />

<div class="row text-center g-4">

    <div class="col-md-3">
        <a asp-controller="Books" asp-action="Index"
               class="btn btn-primary w-100 py-4 shadow admin-btn">
            <div class="fs-3">📚</div>
            <div class="mt-2 fw-semibold">Manage Books</div>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="Authors" asp-action="Index"
               class="btn btn-secondary w-100 py-4 shadow admin-btn">
            <div class="fs-3">✍️</div>
            <div class="mt-2 fw-semibold">Manage Authors</div>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="Genres" asp-action="Index"
               class="btn btn-warning w-100 py-4 shadow admin-btn">
            <div class="fs-3">🏷️</div>
            <div class="mt-2 fw-semibold">Manage Genres</div>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="Countries" asp-action="Index"
               class="btn btn-success w-100 py-4 shadow admin-btn">
            <div class="fs-3">🌍</div>
            <div class="mt-2 fw-semibold">Manage Countries</div>
        </a>
    </div>

</div>