@model BookLibrary.ViewModels.Authors.AuthorDeleteViewModel

@{
    ViewData["Title"] = "Delete Author";
}

<h1 class="text-center text-danger">@ViewData["Title"]</h1>
<hr />

<div class="alert alert-warning text-center">
    Are you sure you want to delete this author?
</div>

<div class="card">
    <div class="card-body">

        <h4> Author: <strong>@Model.FirstName @Model.LastName</strong></h4>
        <h5>From: <strong>@Model.Country</strong> </h5>

        <form asp-action="DeleteConfirmed" method="post">
            <input type="hidden" asp-for="Id" />

            <button type="submit" class="btn btn-danger">
                Delete
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                Cancel
            </a>
        </form>

    </div>
</div>