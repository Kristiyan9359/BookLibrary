@model BookLibrary.ViewModels.Authors.AuthorDeleteViewModel

@{
    ViewData["Title"] = "Delete Author";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">

    <div class="glass-card p-4 text-center" style="max-width: 500px; width: 100%;">

        <h2 class="text-danger mb-3">
            👤 Delete Author
        </h2>

        <p class="text-black mb-4">
            Are you sure you want to delete this author?
        </p>

        <div class="mb-4">
            <h5 class="text-black fw-bold">
                @Model.FirstName @Model.LastName
            </h5>

            <p class="text-muted">
                @Model.Country
            </p>

            <p class="text-muted small">
                This author cannot be deleted if it is assigned to any book.
            </p>
        </div>

        <form asp-action="DeleteConfirmed" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="d-flex justify-content-center gap-3 mt-3">

                <button type="submit" class="btn btn-danger px-4">
                    Delete
                </button>

                <a asp-action="Index" class="btn btn-secondary px-4">
                    Cancel
                </a>

            </div>
        </form>

    </div>

</div>