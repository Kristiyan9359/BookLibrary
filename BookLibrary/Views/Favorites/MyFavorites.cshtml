@model IEnumerable<BookLibrary.ViewModels.Favorites.FavoriteBookViewModel>

@{
    ViewData["Title"] = "My Favorites";
}

<h2 class="text-center mb-4">My Favorites</h2>
<hr />

@if (!Model.Any())
{
    <h5 class="text-start mb-4">You have not added any books to your favorites yet.</h5>
}
else
{
    <div class="row g-4">

        @foreach (var book in Model)
        {
            <div class="col-md-6">

                <div class="glass-card p-3 h-100">

                    <div class="row g-0 align-items-center">

                        <div class="col-4">
                            <img src="@book.ImageUrl"
                                 class="img-fluid rounded"
                                 style="height:250px; object-fit:cover;" />
                        </div>

                        <div class="col-8 ps-3">

                            <div class="d-flex flex-column text-start" style="height:250px;">

                                <h5 class="text-black mb-2">
                                    @book.Title
                                </h5>

                                <h6 class="text-black-50 mb-2">
                                    @book.Author
                                </h6>

                                <div class="mt-auto d-flex gap-2">

                                    <form asp-controller="Favorites"
                                          asp-action="Toggle"
                                          method="post"
                                          class="flex-fill">

                                        <input type="hidden" name="bookId" value="@book.Id" />

                                        <button class="btn btn-outline-danger btn-sm w-100">
                                            💔 Remove
                                        </button>

                                    </form>
                                    <a asp-controller="Books"
                                           asp-action="Details"
                                           asp-route-id="@book.Id"
                                           class="btn btn-primary btn-sm flex-fill">
                                        Details
                                    </a>
                                </div>

                            </div>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>
}