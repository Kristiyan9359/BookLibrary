@model IEnumerable<BookLibrary.ViewModels.Favorites.FavoriteBookViewModel>

@{
    ViewData["Title"] = "My Favorites";
}

<h2 class="text-center mb-4">My Favorites</h2>
<hr />

@if (!Model.Any())
{
    <p>You have not added any books to your favorites yet.</p>
}
else
{
    <div class="row g-4">

        @foreach (var book in Model)
        {
            <div class="col-md-6">

                <div class="card shadow-sm border-0">

                    <div class="row g-0">

                        <div class="col-4">

                            <img src="@book.ImageUrl"
                                 class="img-fluid rounded-start"
                                 style="height:140px; object-fit:cover;" />

                        </div>

                        <div class="col-8">

                            <div class="card-body">

                                <h6 class="card-title">@book.Title</h6>

                                <p class="text-muted small mb-2">
                                    @book.Author
                                </p>

                                <a asp-controller="Books"
                                       asp-action="Details"
                                       asp-route-id="@book.Id"
                                       class="btn btn-sm btn-primary">

                                    Details

                                </a>

                            </div>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>
}