@model IEnumerable<BookLibrary.ViewModels.Favorites.FavoriteBookViewModel>

@{
    ViewData["Title"] = "My Favorites";
}

<h2 class="text-center">My Favorites</h2>
<hr />

@if (!Model.Any())
{
    <p>You have not added any books to your favorites yet.</p>
}
else
{
    <table class="table table-striped">

        <thead>
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th></th>
            </tr>
        </thead>

        <tbody>
            @foreach (var book in Model)
            {
                <tr>

                    <td>@book.Title</td>

                    <td>@book.Author</td>

                    <td>
                        <a asp-controller="Books"
                           asp-action="Details"
                           asp-route-id="@book.Id"
                           class="btn btn-sm btn-outline-primary">

                            View
                        </a>
                    </td>

                </tr>
            }
        </tbody>

    </table>
}
