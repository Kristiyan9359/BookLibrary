@model BookLibrary.ViewModels.Books.BookDetailsViewModel

@{
    ViewData["Title"] = "Book Details";
}

<div class="glass-card p-4">

    <div class="row g-4 align-items-start">

        <div class="col-md-4 text-center">
            <img src="@Model.ImageUrl"
                 class="img-fluid rounded shadow"
                 style="max-height:420px;" />
        </div>

        <div class="col-md-8">

            <h2 class="fw-bold text-dark mb-3">
                📕 @Model.Title
            </h2>

            <div class="mb-3 text-dark">

                <p><i class="bi bi-person me-2 text-secondary"></i><strong>Author:</strong> @Model.Author</p>
                <p><i class="bi bi-globe me-2 text-secondary"></i><strong>Country:</strong> @Model.Country</p>
                <p><i class="bi bi-tag me-2 text-secondary"></i><strong>Genre:</strong> @Model.Genre</p>
                <p><i class="bi bi-calendar me-2 text-secondary"></i><strong>Year:</strong> @Model.Year</p>
                <p><i class="bi bi-file-earmark-text me-2 text-secondary"></i><strong>Pages:</strong> @Model.Pages</p>

            </div>

            @if (User.IsInRole("User"))
            {
                <div class="mb-3 d-flex flex-wrap gap-2">

                    @if (!Model.IsRented)
                    {
                        <form asp-controller="BookRental" asp-action="Rent" method="post">
                            <input type="hidden" name="bookId" value="@Model.Id" />
                            <button class="btn btn-success">
                                <i class="bi bi-book"></i> Rent
                            </button>
                        </form>
                    }
                    else if (Model.IsRentedByCurrentUser)
                    {
                        <form asp-controller="BookRental" asp-action="Return" method="post">
                            <input type="hidden" name="bookId" value="@Model.Id" />
                            <input type="hidden" name="returnUrl"
                                   value="@Url.Action("Details", "Books", new { id = Model.Id })" />
                            <button class="btn btn-warning">
                                <i class="bi bi-arrow-return-left"></i> Return
                            </button>
                        </form>
                    }
                    else
                    {
                        <span class="badge bg-danger p-2">
                            Book is currently rented
                        </span>
                    }

                    <form asp-controller="Favorites" asp-action="Toggle" method="post">
                        <input type="hidden" name="bookId" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger">
                            <i class="bi @(Model.IsFavorite ? "bi-heart-fill" : "bi-heart")"></i>
                            @(Model.IsFavorite ? " Remove from favorites" : " Add to favorites")
                        </button>
                    </form>

                </div>
            }

        </div>

    </div>

</div>

<div class="glass-card p-4 mt-4 text-dark">

    <h4 class="fw-bold mb-3">
        <i class="bi bi-star"></i> Reviews
    </h4>

    @if (!Model.Reviews.Any())
    {
        <p>No reviews yet.</p>
    }
    else
    {
        @foreach (var review in Model.Reviews)
        {
            <div class="review-card mb-3">

                <div class="d-flex justify-content-between mb-2">

                    <span class="fw-semibold">
                        ⭐ @review.Rating / 5
                    </span>

                    <small class="text-muted">
                        @review.CreatedOn.ToString("dd.MM.yyyy")
                    </small>

                </div>

                <p class="mb-0 text-dark">@review.Comment</p>

            </div>
        }
    }

</div>

@if (User.IsInRole("User"))
{
    <div class="glass-card p-4 mt-4">

        <h4 class="fw-bold text-dark mb-3">
            <i class="bi bi-chat-dots"></i> Add Review
        </h4>

        <form asp-controller="Reviews" asp-action="Add" method="post">

            <input type="hidden" name="BookId" value="@Model.Id" />

            <div class="mb-3">
                <label class="form-label fw-bold text-dark">Rating</label>
                <select name="Rating" class="form-select">
                    <option value="">-- Select rating --</option>
                    @for (int i = 1; i <= 5; i++)
                    {
                        <option value="@i">@i</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold text-dark">Comment</label>
                <textarea name="Comment"
                          class="form-control"
                          rows="3"
                          placeholder="Optional comment..."></textarea>
            </div>

            <button type="submit" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Add Review
            </button>

        </form>

    </div>
}

<div class="mt-4 text-center">

    <a asp-action="Index" class="btn btn-secondary">
        Back
    </a>

</div>