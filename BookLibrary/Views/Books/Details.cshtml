@model BookLibrary.ViewModels.Books.BookDetailsViewModel

@{
    ViewData["Title"] = "Book Details";
}

<div class="row mb-4 align-items-start">

    <div class="col-md-4 text-center">
        <img src="@Model.ImageUrl"
             class="img-fluid rounded shadow"
             style="max-height:420px;" />
    </div>

    <div class="col-md-8">

        <h2 class="mb-3 text-dark">@Model.Title</h2>

        <div class="glass-box mb-3">

            <p><strong>Author:</strong> @Model.Author</p>
            <p><strong>Country:</strong> @Model.Country</p>
            <p><strong>Genre:</strong> @Model.Genre</p>
            <p><strong>Year:</strong> @Model.Year</p>
            <p><strong>Pages:</strong> @Model.Pages</p>

        </div>

        @if (User.IsInRole("User"))
        {
            <div class="mb-3">

                @if (!Model.IsRented)
                {
                    <form asp-controller="BookRental" asp-action="Rent" method="post">
                        <input type="hidden" name="bookId" value="@Model.Id" />
                        <button class="btn btn-success">📚 Rent the Book</button>
                    </form>
                }
                else if (Model.IsRentedByCurrentUser)
                {
                    <form asp-controller="BookRental" asp-action="Return" method="post">
                        <input type="hidden" name="bookId" value="@Model.Id" />
                        <input type="hidden" name="returnUrl"
                               value="@Url.Action("Details", "Books", new { id = Model.Id })" />
                        <button class="btn btn-warning">↩ Return Book</button>
                    </form>
                }
                else
                {
                    <span class="badge bg-danger">Book is currently rented</span>
                }
                <form asp-controller="Favorites" asp-action="Toggle" method="post" class="mt-3">
                    <input type="hidden" name="bookId" value="@Model.Id" />
                    <button type="submit"
                            class="btn @(Model.IsFavorite ? "btn-outline-danger" : "btn-outline-primary")">
                        @(Model.IsFavorite ? "💔 Remove from favorites" : "❤️ Add to favorites")
                    </button>
                </form>
            </div>
        }

    </div>

</div>

<hr />

<h4 class="text-black">Reviews</h4>

@if (!Model.Reviews.Any())
{
    <p class="text-black">No reviews yet.</p>
}
else
{
    <div class="glass-box mb-3">

        @foreach (var review in Model.Reviews)
        {
            <div class="review-card mb-3">

                <div class="d-flex justify-content-between align-items-center mb-2">

                    <span class="review-rating">
                        ⭐ @review.Rating / 5
                    </span>

                    <small class="review-date">
                        @review.CreatedOn.ToString("dd.MM.yyyy")
                    </small>

                </div>

                <p class="review-text mb-0">
                    @review.Comment
                </p>

            </div>
        }

    </div>
}

@if (User.IsInRole("User"))
{
    <hr />

    <h4 class="text-black">Add Review</h4>

    <div class="glass-box">

        <form asp-controller="Reviews" asp-action="Add" method="post">
            <input type="hidden" name="BookId" value="@Model.Id" />

            <div class="mb-3">
                <label class="form-label text-black">Rating</label>
                <select name="Rating" class="form-select">
                    <option value="">-- Select rating --</option>
                    @for (int i = 1; i <= 5; i++)
                    {
                        <option value="@i">@i</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label text-black">Comment</label>
                <textarea name="Comment" class="form-control" rows="3"
                          placeholder="Optional comment..."></textarea>
            </div>

            <button type="submit" class="btn btn-success">➕ Add review</button>
        </form>

    </div>
}

<div class="mt-4">

    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning me-2">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger me-2">Delete</a>
    }

    <a asp-action="Index" class="btn btn-secondary">Back to list</a>

</div>