@model IEnumerable<BookLibrary.ViewModels.Books.BookIndexViewModel>

@{
    ViewData["Title"] = "Books";
}

<h2 class="text-center mb-4">Books</h2>
<hr />

@if (User.IsInRole("Admin"))
{
    <a asp-action="Create" class="btn btn-success mb-4">
        ➕ Add new book
    </a>
}

<div class="row g-4">

    @foreach (var book in Model)
    {
        <div class="col-lg-3 col-md-4 col-sm-6">

            <div class="card book-card h-100 shadow-sm">

                <img src="@book.ImageUrl"
                     class="card-img-top"
                     alt="@book.Title" />

                <div class="card-body text-center">

                    <h6 class="card-title">@book.Title</h6>

                    <p class="text-muted small mb-1">
                        @book.Author
                    </p>

                    <p class="small mb-2">
                        @book.Year • @book.Genre
                    </p>

                    @if (book.AverageRating.HasValue)
                    {
                        <span class="badge bg-success mb-2">
                            ⭐ @book.AverageRating.Value.ToString("0.0")
                            <small>(@book.ReviewsCount)</small>
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary mb-2">
                            No reviews
                        </span>
                    }

                    <div>
                        <a asp-action="Details"
                               asp-route-id="@book.Id"
                               class="btn btn-sm btn-primary">
                            Details
                        </a>
                    </div>

                </div>

            </div>

        </div>
    }

</div>