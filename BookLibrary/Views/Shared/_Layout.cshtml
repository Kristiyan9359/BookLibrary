<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookLibrary</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BookLibrary.styles.css" asp-append-version="true" />
</head>

<body class="d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-sm navbar-harbor border-bottom mb-3">
            <div class="container-fluid">

                <a class="navbar-brand text-white fw-bold"
                   asp-controller="Home"
                   asp-action="Index">

                    <i class="bi bi-collection-fill text-warning me-2"></i>
                    Book Library
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @* <li class="nav-item">
                            <a class="nav-link text-white"
                               asp-controller="Home"
                               asp-action="Index">
                                Home
                            </a>
                        </li> *@

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="Books"
                                   asp-action="Index">
                                    <i class="bi bi-book text-info me-1"></i>
                                    Books
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="Authors"
                                   asp-action="Index">
                                    <i class="bi bi-person-lines-fill text-light me-1"></i>
                                    Authors
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="Genres"
                                   asp-action="Index">
                                    <i class="bi bi-tags text-warning me-1"></i>
                                    Genres
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="Countries"
                                   asp-action="Index">
                                    <i class="bi bi-globe text-primary me-1"></i>
                                    Countries
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="Favorites"
                                   asp-action="MyFavorites">
                                    <i class="bi bi-heart text-danger me-1"></i>
                                    My Favorites
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="BookRental"
                                   asp-action="MyRentals">
                                    <i class="bi bi-journal-check text-info me-1"></i>
                                    My Rentals
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-white"
                                   asp-controller="BookRental"
                                   asp-action="History">
                                    <i class="bi bi-clock-history text-black me-1"></i>
                                    Rental History
                                </a>
                            </li>
                        }
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav><link rel="stylesheet"
                    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    </header>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success text-center mb-0">
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger text-center mb-0">
            @TempData["ErrorMessage"]
        </div>
    }

    <main class="container flex-fill">
        <div class="pb-3">
            @RenderBody()
        </div>
    </main>

    <footer class="footer bg-dark text-light mt-auto">
        <div class="container text-center py-3">
            &copy; 2026 - BookLibrary
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>