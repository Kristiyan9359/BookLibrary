@model IEnumerable<BookLibrary.ViewModels.Rentals.RentalViewModel>

@{
    ViewData["Title"] = "My Rentals";
}

<h2 class="text-center mb-4">My Rentals</h2>
<hr />

@if (!Model.Any())
{
    <p>You have no rented books.</p>
}
else
{
    <div class="row g-4">

        @foreach (var rental in Model)
        {
            <div class="col-md-6">

                <div class="card border-0 shadow-sm">

                    <div class="row g-0">

                        <div class="col-4">

                            <img src="@rental.ImageUrl"
                                 class="img-fluid rounded-start"
                                 style="height:150px; object-fit:cover;" />

                        </div>

                        <div class="col-8">

                            <div class="card-body">

                                <h6 class="card-title">
                                    @rental.Title
                                </h6>

                                <p class="text-muted small mb-2">
                                    Rented on:
                                    @rental.RentedOn.ToString("dd.MM.yyyy")
                                </p>

                                <form asp-controller="BookRental"
                                      asp-action="Return"
                                      method="post">

                                    <input type="hidden"
                                           name="bookId"
                                           value="@rental.BookId" />

                                    <input type="hidden"
                                           name="returnUrl"
                                           value="@Url.Action("MyRentals", "BookRental")" />

                                    <button class="btn btn-warning btn-sm">
                                        ↩ Return
                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>
}