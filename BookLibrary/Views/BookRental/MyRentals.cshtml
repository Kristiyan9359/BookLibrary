@model IEnumerable<BookLibrary.ViewModels.Rentals.RentalViewModel>

@{
    ViewData["Title"] = "My Rentals";
}

<h2 class="text-center mb-4">My Rentals</h2>
<hr />

@if (!Model.Any())
{
    <h5 class="text-start mb-4">You have no rented books.</h5>
}
else
{
    <div class="row g-4">

        @foreach (var rental in Model)
        {
            <div class="col-md-6">

                <div class="glass-card p-3 h-100">

                    <div class="row g-0 align-items-center">

                        <div class="col-4">
                            <img src="@rental.ImageUrl"
                                 class="img-fluid rounded"
                                 style="height:150px; object-fit:cover;" />
                        </div>

                        <div class="col-8 ps-3">

                            <div class="d-flex flex-column h-100 text-start">

                                <h6 class="text-black mb-2">
                                    @rental.Title
                                </h6>

                                <p class="text-black small mb-2">
                                    <strong>Rented:</strong>
                                    @rental.RentedOn.ToString("dd.MM.yyyy")
                                </p>

                                <div class="mt-auto d-flex gap-2">

                                    <form asp-controller="BookRental"
                                          asp-action="Return"
                                          method="post"
                                          class="flex-fill">

                                        <input type="hidden"
                                               name="bookId"
                                               value="@rental.BookId" />

                                        <input type="hidden"
                                               name="returnUrl"
                                               value="@Url.Action("MyRentals", "BookRental")" />

                                        <button class="btn btn-warning btn-sm w-100">
                                            ↩ Return
                                        </button>

                                    </form>

                                    <a asp-controller="Books"
                                           asp-action="Details"
                                           asp-route-id="@rental.BookId"
                                           class="btn btn-primary btn-sm flex-fill">

                                        Details
                                    </a>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>
}