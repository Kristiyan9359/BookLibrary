@model IEnumerable<BookLibrary.ViewModels.Rentals.RentalHistoryViewModel>

@{
    ViewData["Title"] = "Rental History";
}

<h2 class="text-center mb-4">Rental History</h2>
<hr />

@if (!Model.Any())
{
    <p>You have no rental history.</p>
}
else
{
    <div class="row g-4">

        @foreach (var rental in Model)
        {
            <div class="col-md-6">

                <div class="card border-0 shadow-sm">

                    <div class="row g-0">

                        <div class="col-4">

                            <img src="@rental.ImageUrl"
                                 class="img-fluid rounded-start"
                                 style="height:150px; object-fit:cover;" />

                        </div>

                        <div class="col-8">

                            <div class="card-body">

                                <h6 class="card-title">
                                    @rental.Title
                                </h6>

                                <p class="text-muted small mb-1">
                                    Rented on:
                                    @rental.RentedOn.ToString("dd.MM.yyyy")
                                </p>

                                <p class="text-muted small mb-2">
                                    Returned on:
                                    @(rental.ReturnedOn.HasValue
                                        ? rental.ReturnedOn.Value.ToString("dd.MM.yyyy")
                                        : "Still rented")
                                </p>

                            </div>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>
}