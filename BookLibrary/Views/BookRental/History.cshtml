@model IEnumerable<BookLibrary.ViewModels.Rentals.RentalHistoryViewModel>

@{
    ViewData["Title"] = "Rental History";
}

<h2 class="text-center mb-4">Rental History</h2>
<hr />

@if (!Model.Any())
{
    <h5 class="text-start mb-4">You have no rental history.</h5>
}
else
{
    <div class="row g-4">

        @foreach (var rental in Model)
        {
            <div class="col-md-6">

                <div class="glass-card p-3 h-100">

                    <div class="row g-0 align-items-center">

                        <div class="col-4">
                            <img src="@rental.ImageUrl"
                                 class="img-fluid rounded"
                                 style="height:250px; object-fit:cover;" />
                        </div>

                        <div class="col-8 ps-3">

                            <div class="d-flex flex-column text-start" style="height:250px;">

                                <h5 class="text-black mb-2">
                                    @rental.Title
                                </h5>

                                <h6 class="text-black-50 mb-2">
                                    @rental.Author
                                </h6>

                                <div class="my-auto">
                                    <p class="text-black small mb-0">
                                        <strong>Rented:</strong>
                                        @rental.RentedOn.ToString("dd.MM.yyyy")
                                    </p>
                                </div>

                                <p class="text-black small mb-0">
                                    <strong>Returned:</strong>
                                    @(rental.ReturnedOn.HasValue
                                        ? rental.ReturnedOn.Value.ToString("dd.MM.yyyy")
                                        : "Still rented")
                                </p>

                            </div>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>
   
}

@{
    int current = ViewBag.CurrentPage;
    int total = ViewBag.TotalPages;

    int start = Math.Max(1, current - 2);
    int end = Math.Min(total, current + 2);
}

@if (total > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">

            <li class="page-item @(current == 1 ? "disabled" : "")">
                <a class="page-link"
                       asp-action="History"
                       asp-route-currentPage="@(current - 1)">
                    ◀
                </a>
            </li>

            @if (start > 1)
            {
                <li class="page-item">
                    <a class="page-link"
                       asp-action="History"
                       asp-route-currentPage="1">1</a>
                </li>

                @if (start > 2)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }
            }

            @for (int i = start; i <= end; i++)
            {
                <li class="page-item @(i == current ? "active" : "")">
                    <a class="page-link"
                           asp-action="History"
                           asp-route-currentPage="@i">
                        @i
                    </a>
                </li>
            }

            @if (end < total)
            {
                @if (end < total - 1)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                <li class="page-item">
                    <a class="page-link"
                           asp-action="History"
                           asp-route-currentPage="@total">
                        @total
                    </a>
                </li>
            }

            <li class="page-item @(current == total ? "disabled" : "")">
                <a class="page-link"
                       asp-action="History"
                       asp-route-currentPage="@(current + 1)">
                    ▶
                </a>
            </li>

        </ul>
    </nav>
}