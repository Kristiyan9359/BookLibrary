@model IEnumerable<BookLibrary.ViewModels.Rentals.RentalHistoryViewModel>

@{
    ViewData["Title"] = "Rental History";
}

<h2 class="text-center mb-4">Rental History</h2>
<hr />

@if (!Model.Any())
{
    <h5 class="text-start mb-4">You have no rental history.</h5>
}
else
{
    <div class="row g-4">

        @foreach (var rental in Model)
        {
            <div class="col-md-6">

                <div class="glass-card p-3 h-100">

                    <div class="row g-0 align-items-center">

                        <div class="col-4">
                            <img src="@rental.ImageUrl"
                                 class="img-fluid rounded"
                                 style="height:250px; object-fit:cover;" />
                        </div>

                        <div class="col-8 ps-3">

                            <div class="d-flex flex-column text-start" style="height:250px;">

                                <h5 class="text-black mb-2">
                                    @rental.Title
                                </h5>

                                <h6 class="text-black-50 mb-2">
                                    @rental.Author
                                </h6>

                                <div class="my-auto">
                                    <p class="text-black small mb-0">
                                        <strong>Rented:</strong>
                                        @rental.RentedOn.ToString("dd.MM.yyyy")
                                    </p>
                                </div>

                                <p class="text-black small mb-0">
                                    <strong>Returned:</strong>
                                    @(rental.ReturnedOn.HasValue
                                        ? rental.ReturnedOn.Value.ToString("dd.MM.yyyy")
                                        : "Still rented")
                                </p>

                            </div>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>
}